# ===========================
# PRINTVOLTRABOT - Environment
# ===========================

# Telegram Bot Token (@BotFather dan oling)
BOT_TOKEN=your_bot_token_here

# Telegram Guruh/Kanal ID (manfiy bo'ladi guruh uchun)
GROUP_CHAT_ID=-1001234567890

# Admin User IDs (vergul bilan ajrating)
ADMIN_IDS=123456789,987654321

# ===========================
# ERP API
# ===========================
ERP_API_URL=https://your-erp-api.com/api
ERP_API_TOKEN=your_erp_api_token
ERP_API_SECRET=your_erp_api_secret

# ===========================
# Yandex Delivery API
# ===========================
YANDEX_API_URL=https://b2b.taxi.yandex.net/b2b/cargo/integration/v2
YANDEX_OAUTH_TOKEN=your_yandex_oauth_token
YANDEX_CLIENT_ID=your_yandex_client_id

# ===========================
# Database (PostgreSQL)
# ===========================
DATABASE_URL=postgresql://printvoltra:password@localhost:5432/printvoltradb

# ===========================
# Kompaniya Ma'lumotlari (PDF uchun)
# ===========================
COMPANY_NAME=Ibox.uz
COMPANY_ADDRESS=Toshkent, O'zbekiston
COMPANY_PHONE=+998 XX XXX XX XX
COMPANY_EMAIL=info@ibox.uz
COMPANY_WEBSITE=https://ibox.uz
COMPANY_INN=123456789

# ===========================
# PDF Settings
# ===========================
PDF_OUTPUT_DIR=./temp/pdfs
LOGO_PATH=./assets/logo.png

# ===========================
# App Settings
# ===========================
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
