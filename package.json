{
  "name": "printvoltrabot",
  "version": "1.0.0",
  "description": "Professional ERP Zayafka Telegram Bot - nakladnoy va garant PDF generator",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc && mkdir -p dist/pdf/templates && cp -r src/pdf/templates/* dist/pdf/templates/",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.1",
    "@grammyjs/conversations": "^1.2.0",
    "@grammyjs/menu": "^1.2.0",
    "@prisma/client": "^5.13.0",
    "axios": "^1.7.0",
    "dayjs": "^1.11.11",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "grammy": "^1.31.0",
    "handlebars": "^4.7.8",
    "node-cron": "^3.0.3",
    "puppeteer": "^24.42.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.4",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/handlebars": "^4.1.0",
    "@types/node": "^20.12.12",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.5",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "eslint": "^8.57.0",
    "prisma": "^5.13.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
